NODE_ENV=development
PORT=5901
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,http://localhost:8081

# Database (PostgreSQL)
DATABASE_URL="postgresql://user:password@localhost:5432/solana_bank?schema=public"

# Solana Configuration
SOLANA_RPC_URL="https://api.devnet.solana.com"
SYSTEM_WALLET_PRIVATE_KEY="YOUR_BASE58_ENCODED_PRIVATE_KEY"
SYSTEM_WALLET_PUBLIC_KEY="YOUR_PUBLIC_KEY"
CNGN_TOKEN_ADDRESS="target_cngn_mint_address_here"

# Ethereum Configuration
ETH_RPC_URL="https://sepolia.infura.io/v3/YOUR_INFURA_PROJECT_ID"
ETH_ACCOUNT_CONTRACT_ADDRESS="0x0000000000000000000000000000000000000000"
ETH_TRANSFER_CONTRACT_ADDRESS="0x0000000000000000000000000000000000000000"
ETH_CHAIN_ID=11155111

# Security
JWT_SECRET="your_jwt_secret_here"
AES_SECRET="your_aes_encryption_secret_here_32_chars"

# Redis (for BullMQ)
REDIS_HOST=localhost
REDIS_PORT=6379

# Supabase Configuration
SUPABASE_URL="https://your-project-ref.supabase.co"
SUPABASE_PUBLISHABLE_KEY="your_supabase_anon_key"
SUPABASE_SECRET_KEY="your_supabase_service_role_key"
SUPABASE_JWKS_URL="https://your-project-ref.supabase.co/auth/v1/jwks"


PAYSTACK_SECRET_KEY=sk_test_secret_key_here
PAYSTACK_PUBLIC_KEY=pk_test_public_key_here

# Dojah KYC Sandbox API
# 1. Create a free account at https://dashboard.dojah.io
# 2. Get your sandbox keys from Developer -> Configuration -> API Keys
# 3. Use BVN: 22222222222 or NIN: 70123456789 to test successfully
DOJAH_APP_ID=your_dojah_sandbox_app_id
DOJAH_PRIVATE_KEY=your_dojah_sandbox_private_key